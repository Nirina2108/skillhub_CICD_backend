APP_NAME=SkillHub
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
LOG_CHANNEL=stack
LOG_LEVEL=debug


# DOCKER (docker compose up --build) — valeurs par défaut
# Le prof utilise ces valeurs — rien à changer

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=skillhub
DB_USERNAME=skillhub
DB_PASSWORD=skillhub_pass
MYSQL_ROOT_PASSWORD=rootpassword

MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DATABASE=skillhub_messages
MONGO_USERNAME=
MONGO_PASSWORD=
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=mongopassword

JWT_SECRET=
JWT_TTL=60

NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@skillhub.com
MAIL_FROM_NAME="${APP_NAME}"

SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local


# DÉVELOPPEMENT LOCAL (php artisan serve + WAMP)
# Copier ces valeurs dans votre .env local et décommenter

# APP_ENV=local
# APP_DEBUG=true
#
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=skillhub_db
# DB_USERNAME=root
# DB_PASSWORD=
#
# MONGO_HOST=127.0.0.1
# MONGO_PORT=27017
# MONGO_DATABASE=skillhub_logs
# MONGO_USERNAME=
# MONGO_PASSWORD=
#
# JWT_SECRET=        # générer avec : php artisan jwt:secret
# APP_KEY=           # générer avec : php artisan key:generate
#
# SESSION_DRIVER=database
# CACHE_STORE=database
# QUEUE_CONNECTION=database
#
# MAIL_MAILER=log
# MAIL_HOST=127.0.0.1
# MAIL_PORT=2525
# MAIL_USERNAME=null
# MAIL_PASSWORD=null
# MAIL_FROM_ADDRESS=hello@example.com